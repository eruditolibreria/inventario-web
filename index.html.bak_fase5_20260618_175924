  /* Toast */
  #toastContainer {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
    pointer-events: none;
  }
  .toast {
    background: var(--surface3);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 16px;
    font-size: 13px;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 240px;
    max-width: 340px;
    pointer-events: all;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    animation: toastIn 0.25s ease;
  }
  .toast.saliendo { animation: toastOut 0.3s ease forwards; }
  @keyframes toastIn {
    from { opacity:0; transform:translateY(-12px); }
    to   { opacity:1; transform:translateY(0); }
  }
  @keyframes toastOut {
    from { opacity:1; transform:translateY(0); }
    to   { opacity:0; transform:translateY(-12px); }
  }
  .toast-msg { flex:1; font-weight:600; }
  .toast-undo {
    background: var(--accent);
    color: #000;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    font-family: var(--font);
    white-space: nowrap;
  }
  .toast-progress {
    position: absolute;
    top: 0; left: 0;
    height: 3px;
    background: var(--accent);
    border-radius: 10px 10px 0 0;
    transition: width linear;
  }

  /*— Swipe en filas del carrito — */
  #carritoBody tr {
    position: relative;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  #carritoBody tr.swipe-out {
    transform: translateX(80px);
    opacity: 0;
  }

  /* — Atajos de teclado: highlight del input activo — */
  input:focus { outline: none; }

          /* ============================================
             SCROLLBAR PERSONALIZADA
             ============================================ */
          /* WebKit (Chrome, Safari, Edge, Opera) */
          ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
          }
          ::-webkit-scrollbar-track {
            background: var(--surface2);
            border-radius: 10px;
          }
          ::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 10px;
            transition: background 0.2s;
          }
          ::-webkit-scrollbar-thumb:hover {
            background: var(--accent);
          }
          /* Firefox */
          * {
            scrollbar-width: thin;
            scrollbar-color: var(--border) var(--surface2);
          }
          /* Scrollbar en modo claro */
          [data-theme='light'] ::-webkit-scrollbar-track {
            background: #e8ecf1;
          }
          [data-theme='light'] ::-webkit-scrollbar-thumb {
            background: #c0c8d4;
          }
          [data-theme='light'] ::-webkit-scrollbar-thumb:hover {
            background: #00c853;
          }
          [data-theme='light'] * {
            scrollbar-color: #c0c8d4 #e8ecf1;
          }

          /* Scroll suave en toda la pagina */
          html {
            scroll-behavior: smooth;
          }

          /* ============================================
             ANIMACIONES NUEVAS
             ============================================ */

          /* Pulse sutil para botones principales */
          @keyframes pulse-soft {
            0%, 100% { box-shadow: 0 0 0 0 var(--accent-glow); }
            50% { box-shadow: 0 0 0 6px rgba(0,230,118,0); }
          }
          .btn-primary {
            animation: pulse-soft 2.5s ease-in-out infinite;
          }

          /* Shimmer / brillo tipo loading */
          @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
          }
          .shimmer {
            background: linear-gradient(90deg, var(--surface2) 25%, var(--surface3) 50%, var(--surface2) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s ease-in-out infinite;
            border-radius: 8px;
          }

          /* Slide-in desde abajo (paneles, cards) */
          @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
          }
          .slide-up {
            animation: slideUp 0.35s ease forwards;
          }

          /* Scale-in (modales, popups) */
          @keyframes scaleIn {
            from { opacity: 0; transform: scale(0.92); }
            to   { opacity: 1; transform: scale(1); }
          }
          .scale-in {
            animation: scaleIn 0.25s ease forwards;
          }

          /* Bounce suave para notificaciones / badges */
          @keyframes bounce-soft {
            0%, 100% { transform: translateY(0); }
            40% { transform: translateY(-4px); }
            60% { transform: translateY(-2px); }
          }
          .bounce-soft {
            animation: bounce-soft 0.6s ease;
          }




          /* Animacion de entrada para el login */

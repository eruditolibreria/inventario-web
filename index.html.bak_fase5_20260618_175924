        <script>
            // TEMA CLARO/OSCURO
            (function() {
                const saved = localStorage.getItem('theme');
                const icon = document.getElementById('themeIcon');
                if (saved === 'light') {
                    document.documentElement.setAttribute('data-theme', 'light');
                    document.querySelector('meta[name=theme-color]').content = '#f0f2f5';
                    if (icon) icon.innerHTML = '<i class="fa-solid fa-sun"></i>';
                } else {
                    if (icon) icon.innerHTML = '<i class="fa-solid fa-moon"></i>';
                }
            })();
            function toggleTheme() {
                /* Circular Reveal al estilo Telegram usando View Transitions API */
                const html = document.documentElement;
                const meta = document.querySelector('meta[name=theme-color]');
                const icon = document.getElementById('themeIcon');
                const btn = document.getElementById('themeToggleBtn');
                const isLight = html.getAttribute('data-theme') === 'light';

                /* Determinar el nuevo tema */
                const newTheme = isLight ? 'dark' : 'light';
                const newThemeColor = newTheme === 'dark' ? '#080b0f' : '#f0f2f5';
                const iconHTML = newTheme === 'dark'
                    ? '<i class="fa-solid fa-moon"></i>'
                    : '<i class="fa-solid fa-sun"></i>';

                /* Calcular posición del botón para iniciar la animación desde ahí */
                if (btn) {
                    const rect = btn.getBoundingClientRect();
                    const cx = rect.left + rect.width / 2;   /* centro X del botón */
                    const cy = rect.top + rect.height / 2;    /* centro Y del botón */

                    /* Calcular el radio máximo necesario para cubrir toda la pantalla */
                    const maxRadius = Math.hypot(
                        Math.max(cx, window.innerWidth - cx),
                        Math.max(cy, window.innerHeight - cy)
                    );

                                        /* Setear variables CSS para la animación circular */
                    /* Solo pasamos coordenadas simples; la lógica de dirección está en los keyframes */
                    html.style.setProperty('--tx', cx + 'px');
                    html.style.setProperty('--ty', cy + 'px');
                    html.style.setProperty('--tr', maxRadius + 'px');
                }

                                /* Verificar soporte de View Transitions API */
                if (document.startViewTransition) {
                    /* Indicar dirección para que CSS sepa qué capa animar */
                    html.setAttribute('data-theme-direction', newTheme === 'light' ? 'expand' : 'retract');

                    /* Navegador moderno: animación circular */
                    document.startViewTransition(function() {
                        /* Cambiar el tema dentro del callback */
                        if (newTheme === 'dark') {
                            html.removeAttribute('data-theme');
                        } else {
                            html.setAttribute('data-theme', 'light');
                        }
                        meta.content = newThemeColor;
                        localStorage.setItem('theme', newTheme);
                        icon.innerHTML = iconHTML;
                    });
                } else {
                    /* Fallback: cambio instantáneo sin animación */
                    if (newTheme === 'dark') {
                        html.removeAttribute('data-theme');
                    } else {
                        html.setAttribute('data-theme', 'light');
                    }
                    meta.content = newThemeColor;
                    localStorage.setItem('theme', newTheme);
                    icon.innerHTML = iconHTML;
                }
            }

            // CODIGO ORIGINAL
            if ('serviceWorker'in navigator) {
                window.addEventListener('load', () => {
                    navigator.serviceWorker.register('/sw.js');
                }
                );
            }
        </script>

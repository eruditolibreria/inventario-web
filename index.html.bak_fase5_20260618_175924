          #printArea .print-summary { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 10px; }
          #printArea .print-summary-card { border: 1px solid #ddd; padding: 10px 16px; border-radius: 6px; flex: 1; min-width: 120px; text-align: center; }
          #printArea .print-summary-card .psc-label { font-size: 10px; color: #555 !important; }

            0% { box-shadow: 0 0 10px rgba(0,230,118,0); }
            100% { box-shadow: 0 0 40px rgba(0,230,118,0.12); }
          }
          .panel {
            animation: panelGlow 1.2s ease forwards;
          }

                    /* Transicion suave al cambiar de seccion */
          .seccion-transition {
            animation: fadeIn 0.25s ease;
          }

          /* Hover effects para cards en dispositivos con hover */
          @media (hover: hover) {
            .inventario-card:hover,
            .caja-card:hover,
            .lamina-card:hover,
            .usuario-card:hover,
            .srv-resumen-bloque:hover {
              border-color: var(--accent);
              box-shadow: 0 0 20px var(--accent-dim);
              transition: all 0.25s ease;
            }
          }

          /* En mobile no hay hover, aseguramos que no haya efectos raros */
          @media (hover: none) {
            .inventario-card:hover,
            .caja-card:hover,
            .lamina-card:hover,
            .usuario-card:hover,
            .srv-resumen-bloque:hover {
              border-color: var(--border);
              box-shadow: none;
            }
          }
          /* BOTON TOGGLE TEMA — Circular Reveal (Telegram-style) */
          .theme-toggle {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 50%;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: border-color 0.2s ease, background 0.3s ease, transform 0.2s ease;
            flex-shrink: 0;
            margin-right: 6px;
            position: relative;
            z-index: 100;
          }
          .theme-toggle:hover {
            border-color: var(--accent);
            transform: scale(1.08);
          }
          .theme-toggle:active {
            transform: scale(0.94);
          }
                    .theme-toggle-icon {
            font-size: 17px;
            line-height: 1;
            transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            display: flex;
            align-items: center;
            justify-content: center;
          }
          /* Luna iluminada en amarillo en tema oscuro */
          .theme-toggle-icon .fa-moon {
            color: #f5c542;
          }
          [data-theme='light'] .theme-toggle-icon {
            transform: rotate(180deg);
          }
          @media (min-width: 1024px) {
            .theme-toggle { width: 42px; height: 42px; }
            .theme-toggle-icon { font-size: 19px; }
          }

                    /* ===== CIRCULAR REVEAL — View Transitions API ===== */
          /*
           * Dirección controlada por data-theme-direction en el HTML:
           *   expand  (→ claro):  anima ::view-transition-new (círculo crece)
           *   retract (→ oscuro): anima ::view-transition-old (círculo se encoge)
           * Esto evita el parpadeo al cambiar a tema claro.
           */

          /* Fondo del viewport durante la transicion (se ve al encogerse la capa old) */
          ::view-transition {
            background-color: var(--bg, #080b0f);
          }

          [data-theme-direction="expand"]::view-transition-new(root) {
            animation: circularRevealExpand 450ms cubic-bezier(0.4, 0, 0.2, 1) forwards;
          }
          [data-theme-direction="expand"]::view-transition-old(root) {
            animation: none;
          }
          [data-theme-direction="retract"]::view-transition-old(root) {
            animation: circularRevealRetract 450ms cubic-bezier(0.4, 0, 0.2, 1) forwards;
          }
          [data-theme-direction="retract"]::view-transition-new(root) {
            animation: none;
            opacity: 0;
          }

                    @keyframes circularRevealExpand {
            from { clip-path: circle(0% at var(--tx, 50%) var(--ty, 50%)); }
            to   { clip-path: circle(var(--tr, 150vmax) at var(--tx, 50%) var(--ty, 50%)); }
          }
          @keyframes circularRevealRetract {
            from { clip-path: circle(var(--tr, 150vmax) at var(--tx, 50%) var(--ty, 50%)); }
            to   { clip-path: circle(0% at var(--tx, 50%) var(--ty, 50%)); }
          }

          /* Respetar prefers-reduced-motion: desactivar animación circular */
          @media (prefers-reduced-motion: reduce) {
            ::view-transition-new(root) {
              animation: none !important;
            }
            ::view-transition-old(root) {
              animation: none !important;
            }
          }


          /* Transicion suave al cambiar de tema */
          *, *::before, *::after {
            transition: background-color 0.3s ease,
                        border-color 0.25s ease,
                        color 0.25s ease,
                        box-shadow 0.25s ease;
          }
          body { transition: background-color 0.3s ease, padding 0.3s ease; }

                /* Ocultar printArea en pantalla */
        #printArea { display: none; }

        /* ===== PDF PRINT STYLES ===== */
        @media print {
          /* Hide everything except the receipt/report */
          body > *:not(#printArea) { display: none !important; }
          #printArea {
            display: block !important;
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;

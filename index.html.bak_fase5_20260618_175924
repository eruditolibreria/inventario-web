        <style>
            :root {
                --bg: #080b0f;
                --surface: #0f1318;
                --surface2: #161c24;
                --surface3: #1c2530;
                --border: #1e2d3d;
                --accent: #00e676;
                --accent-dim: rgba(0,230,118,0.12);
                --accent-glow: rgba(0,230,118,0.25);
                --orange: #ff9800;
                --red: #ff4757;
                --blue: #2979ff;
                --purple: #b388ff;
                --teal: #00bcd4;
                --text: #dde6f0;
                --muted: #4a6278;
                --red-dim: rgba(255,71,87,0.12);
                --orange-dim: rgba(255,152,0,0.15);
                --blue-dim: rgba(41,121,255,0.15);
                --font: 'Outfit',sans-serif;
                --mono: 'DM Mono',monospace;
            }

            /* ===== TEMA CLARO ===== */
            [data-theme='light'] {
                --bg: #f0f2f5;
                --surface: #ffffff;
                --surface2: #f4f6f9;
                --surface3: #e8ecf1;
                --border: #d0d7de;
                --accent: #00c853;
                --accent-dim: rgba(0,200,83,0.10);
                --accent-glow: rgba(0,200,83,0.20);
                --orange: #e65100;
                --red: #d32f2f;
                --blue: #1565c0;
                --purple: #7c4dff;
                --teal: #00838f;
                --red-dim: rgba(211,47,47,0.12);
                --orange-dim: rgba(230,81,0,0.12);
                --blue-dim: rgba(21,101,192,0.12);
                --text: #1a2332;
                --muted: #6b7f94;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                background: var(--bg);
                font-family: var(--font);
                color: var(--text);
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: flex-start;
                padding: 20px 12px 40px;
            }

            /* ===== RESPONSIVE ===== */
            html { transition: padding 0.3s ease; }
            @media (min-width: 768px) {
                body { padding: 24px 32px 48px; }
            }
            @media (min-width: 1024px) {
                body { padding: 32px 48px 64px; }
            }
            @media (min-width: 1440px) {
                body { padding: 40px 64px 80px; }
            }

            body::before {
                content: '';
                position: fixed;
                top: -30vh;
                left: -20vw;
                width: 60vw;
                height: 60vh;
                background: radial-gradient(ellipse,rgba(0,230,118,0.04) 0%,transparent 70%);
                pointer-events: none;
                animation: orb 12s ease-in-out infinite alternate;
            }

            @keyframes orb {
                from {
                    transform: translate(0,0);
                }

                to {
                    transform: translate(20vw,15vh);
                }
            }
            @keyframes slideInFromRight {
                from { opacity: 0; transform: translateX(20px); }
                to   { opacity: 1; transform: translateX(0); }
            }
            @keyframes slideInFromLeft {
                from { opacity: 0; transform: translateX(-20px); }
                to   { opacity: 1; transform: translateX(0); }
            }
            /* Push-out animations para transicion entre pestanas */
            @keyframes slideOutToLeft {
                from { opacity: 1; transform: translateX(0); }
                to   { opacity: 0; transform: translateX(-60px); }
            }
            @keyframes slideOutToRight {
                from { opacity: 1; transform: translateX(0); }
                to   { opacity: 0; transform: translateX(60px); }
            }
            /* Seccion con transicion suave para snap-back/completion */
            .seccion.push-transitioning {
                transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1), opacity 0.35s ease;
                will-change: transform, opacity;
            }
            .seccion.push-dragging {
                transition: none !important;
                will-change: transform;
                pointer-events: none;
            }
            /* Respetar prefers-reduced-motion */
            @media (prefers-reduced-motion: reduce) {
                .mode-tab .tab-icon,
                .nav-indicator,
                .mode-tab,
                .contenido-slider,
                .seccion,
                .seccion.push-transitioning,
                .seccion.push-dragging {
                    transition: none !important;
                    animation: none !important;
                }
            }
            

          #printArea .print-footer { text-align: center; font-size: 10px; color: #888 !important; margin-top: 20px; border-top: 1px solid #ccc; padding-top: 10px; }
          #printArea .print-row-2 { display: flex; gap: 16px; margin-bottom: 8px; }
          #printArea .print-row-2 > div { flex: 1; }
        }
        @media print {
          .no-print { display: none !important; }
        }

            /* ===== BARRA DE NAVEGACION HORIZONTAL SCROLLABLE ===== */
            .mode-tabs {
                display: flex;
                flex-wrap: nowrap;
                overflow-x: auto;
                overflow-y: hidden;
                scroll-behavior: smooth;
                gap: 2px;
                background: var(--surface2);
                border-radius: 12px;
                padding: 6px 4px;
                margin-bottom: 14px;
                border: 1px solid var(--border);
                position: relative;
                scrollbar-width: thin;
                scrollbar-color: var(--accent-dim) transparent;
                -webkit-overflow-scrolling: auto;
            }

            .mode-tabs::-webkit-scrollbar { height: 3px; }
            .mode-tabs::-webkit-scrollbar-track { background: transparent; }
            .mode-tabs::-webkit-scrollbar-thumb {
                background: var(--accent-dim);
                border-radius: 10px;
            }

            /* Indicador animado bajo la pestana activa */
            .nav-indicator {
                position: absolute;
                bottom: 6px;
                height: 3px;
                background: var(--accent);
                border-radius: 3px;
                transition: left 0.35s cubic-bezier(0.25, 0.8, 0.25, 1.2),
                            width 0.35s cubic-bezier(0.25, 0.8, 0.25, 1.2);
                pointer-events: none;
                z-index: 2;
                box-shadow: 0 0 8px var(--accent-glow);
            }

            @media (min-width: 768px) {
                .mode-tabs { gap: 3px; padding: 6px; }
                .mode-tab { padding: 10px 12px; font-size: 12px; }
            }
            @media (min-width: 1024px) {
                .mode-tabs { gap: 4px; padding: 8px; border-radius: 14px; }
                .mode-tab { padding: 12px 16px; font-size: 13px; border-radius: 10px; }

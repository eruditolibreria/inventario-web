                padding: 8px 10px;
                border-radius: 8px;
                text-align: center;
                cursor: pointer;
                font-size: 10px;
                font-weight: 600;
                color: var(--muted);
                transition: color 0.25s, background 0.25s;
                line-height: 1.3;
                white-space: nowrap;
                position: relative;
                z-index: 1;
                user-select: none;
                -webkit-tap-highlight-color: transparent;
            }

            .mode-tab.active {
                color: var(--accent);
                background: transparent;
